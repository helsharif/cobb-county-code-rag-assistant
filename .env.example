# Copy this file to .env locally and fill in the values you want to use.
# Do not commit .env.

# Required for default OpenAI LLM and embeddings.
OPEN_API_KEY=

# Optional Gemini provider.
GEMINI_API_KEY=

# Provider choices: openai or gemini
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# Model choices
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# RAG tuning. These are character counts, roughly 500-1000 tokens per chunk.
CHUNK_SIZE=3500
CHUNK_OVERLAP=500
RETRIEVER_K=5
MIN_RELEVANCE_SCORE=0.30

# Optional LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=cobb-county-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional placeholder for hosted Chroma setups. Local Chroma does not require it.
CHROMA_API_KEY=
